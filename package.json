{
  "name": "ecommerce-node-api",
  "version": "1.0.0",
  "description": "Este é um projeto acadêmico para pratica de desenvolvimento de software mais especificamente a aplicação do paradigma orientado a objeto (POO) e seus conceitos, implementação de aplicaões WEB e APIs, integração com banco de dados, utilização de testes automatizados, tudo em conformmidade com principios e padrões de arquitetura e projeto, além de observância às boas práticas de desenvolvimento. Uso do ambiente de execução Node e linguagem de programação TypeScript.",
  "keywords": [
    "processo de desenvolvimento de software",
    "aplicações web",
    "API",
    "principios e padroes de arquitetura",
    "principios e padroes de projeto",
    "projeto",
    "testes automatizados",
    "boas práticas",
    "typescript",
    "node",
    "academico",
    "ifs",
    "programacao II",
    "programacao III"
  ],
  "license": "ISC",
  "author": "Ernesto Silva",
  "main": "index.js",
  "scripts": {
    "dev": "node -r tsconfig-paths/register -r sucrase/register src/index.ts",
    "dev:console": "node -r tsconfig-paths/register -r sucrase/register src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui"
  },
  "prisma": {
    "schema": "src/main/infra/database/orm/prisma/schema.prisma"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@prisma/engines": "^7.8.0",
    "@types/node": "^26.1.0",
    "@vitest/ui": "^4.1.9",
    "prisma": "^7.8.0",
    "sucrase": "^3.35.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.22.0"
  }
}
